# This file is sourced by build.sh to set environment variables for the build.
#
# Env file namespaces:
#   BUILD_ARG_<NAME>="value"  -> forwarded to podman build as --build-arg <NAME>=value
#                                (prefix stripped; only these become build-args)
#   <NAME>="value"            -> consumed by build.sh only, never forwarded.
#                                e.g. DOCKERFILE selects which Dockerfile to build.
#
# The image tag is derived from BUILD_ARG_OMADA_VER if set, else from --set-ver.
DOCKERFILE="Dockerfile"

# Omada package (passed to the Dockerfile as OMADA_VER / OMADA_DOWNLOAD_URL / OMADA_SHA512)
BUILD_ARG_OMADA_VER="6.2.14.11"
BUILD_ARG_OMADA_DOWNLOAD_URL="https://static.tp-link.com/upload/software/2026/202607/20260717/Omada_SDN_Controller_v6.2.14.11_linux_x64.tar.gz"
# TP-Link publishes no official checksum; maintained manually. Empty skips verification.
BUILD_ARG_OMADA_SHA512="7462ecd6b64bf7d926f11df6eeff4a9b9efba1c40d59526af9bec58ffaf2c37ee281372ebd46db0fb0f36353e5c4a565149a11c757314788587f99a47a8d34af"
# The directory name of the extracted Omada package. If not set, derived from the package filename.
BUILD_ARG_OMADA_DIR="Omada_Network_Application_v6.2.14.11_linux_x64"

# Dependencies
BUILD_ARG_MONGO_VER="8.0.26"
BUILD_ARG_JAVA_VER="21"
BUILD_ARG_JSVC_VER="1.4.1"
BUILD_ARG_OS_BASE="ubuntu:24.04"
