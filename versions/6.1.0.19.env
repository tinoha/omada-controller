# Omada Controller v6.1.0.19 — built from its existing standalone Dockerfile.
# This env file declares no BUILD_ARG_* entries, so build.sh passes zero
# --build-arg values and the Dockerfile's baked-in ARG defaults stay in effect.
# Only DOCKERFILE is set; it selects which Dockerfile to build.
DOCKERFILE="omada_v6.1.0.19.Dockerfile"
